SELECT
    trading.tradingItemId,
    trading.currencyid,
    dailyValue.valuedate,
    dailyValue.dataitemid,
    dailyValue.value,
    dataitem.dataitemname,
    currency.ISOcode
FROM MSCIIndexTradingItem trading
JOIN MSCIIndexDailyValue dailyValue
    ON dailyValue.tradingItemId = trading.tradingItemId
JOIN ciqdataitem dataitem
    ON dataitem.dataitemid = dailyValue.dataitemid
JOIN ciqcurrency currency
    ON currency.currencyid = trading.currencyid
WHERE
    trading.indexid = {{ index_id }}
{% if currency_id %}
    AND trading.currencyid = {{ currency_id }}
{% endif %}
{% if isocode %}
    AND currency.ISOcode = '{{ isocode }}'
{% endif %}
    AND trading.tradingitemtypeid = {{ return_type | default(4, true) }}
    AND dataitem.dataitemid = {{ data_item_id | default(112099, true) }}
{% if date_from %}
    AND dailyValue.valuedate >= '{{ date_from }}'
{% endif %}
{% if date_to %}
    AND dailyValue.valuedate <= '{{ date_to }}'
{% endif %}
ORDER BY dailyValue.valuedate ASC
